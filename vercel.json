{
  "version": 2,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.casinosapi.com"
        }
      ],
      "destination": "https://casinosapi.com/:path*",
      "permanent": true
    },
    {
      "source": "/api-docs",
      "destination": "/api-docs/openapi.yaml",
      "permanent": true
    },
    {
      "source": "/bonuses",
      "destination": "/mini-app",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/api-docs/openapi.yaml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/yaml"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, X-API-Key"
        },
        {
          "key": "X-API-Version",
          "value": "2.0.0"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/bonuses",
      "destination": "/public/mini-app/index.html"
    },
    {
      "source": "/bonus",
      "destination": "/api/bonus.js"
    },
    {
      "source": "/recommendations",
      "destination": "/api/recommendations.js"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/public/sitemap.xml"
    },
    {
      "source": "/api/index.json",
      "destination": "/public/api/index.json"
    },
    {
      "source": "/api/search",
      "destination": "/api/search.js"
    },
    {
      "source": "/api/casino",
      "destination": "/api/casino.js"
    },
    {
      "source": "/api/compare",
      "destination": "/api/compare.js"
    },
    {
      "source": "/api/casinos",
      "destination": "/api/casinos.js"
    },
    {
      "source": "/api/country",
      "destination": "/api/country_filter.js"
    },
    {
      "source": "/api/submit",
      "destination": "/api/submit.js"
    },
    {
      "source": "/api/review",
      "destination": "/api/review.js"
    },
    {
      "source": "/submit",
      "destination": "/public/submit.html"
    },
    {
      "source": "/api/bot",
      "destination": "/api/bot.js"
    },
    {
      "source": "/submit",
      "destination": "/public/submit.html"
    },
    {
      "source": "/mini-app",
      "destination": "/public/mini-app/index.html"
    },
    {
      "source": "/mini-app/:path*",
      "destination": "/public/mini-app/index.html"
    }
  ]
}
