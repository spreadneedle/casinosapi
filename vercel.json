{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.grokcasino.online"
        }
      ],
      "destination": "https://grokcasino.online/:1",
      "permanent": true
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/bonus",
      "dest": "/api/bonus.js"
    },
    {
      "src": "/recommendations",
      "dest": "/api/recommendations.js"
    }
  ]
} 