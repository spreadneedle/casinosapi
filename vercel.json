{
  "version": 2,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.grokcasino.online"
        }
      ],
      "destination": "https://grokcasino.online/:path*",
      "permanent": true
    },
    {
      "source": "/api-docs",
      "destination": "/api-docs/openapi.yaml",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/api-docs/openapi.yaml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/yaml"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/bonus",
      "destination": "/api/bonus.js"
    },
    {
      "source": "/recommendations",
      "destination": "/api/recommendations.js"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/public/sitemap.xml"
    },
    {
      "source": "/api/index.json",
      "destination": "/public/api/index.json"
    }
  ]
}